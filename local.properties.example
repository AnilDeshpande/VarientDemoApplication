# local.properties.example
# ─────────────────────────────────────────────────────────────
# Copy this file to local.properties and fill in real values.
# local.properties is git-ignored and never committed.
#
# On CI, these same values come from environment variables
# (GitHub Actions Secrets). The Gradle build checks env vars
# first, then falls back to local.properties.
# ─────────────────────────────────────────────────────────────

# Android SDK path (auto-generated by Android Studio)
# sdk.dir=/path/to/your/Android/sdk

# ── COMMON (same for all variants) ──────────────────────────
ANALYTICS_SDK_KEY=your-analytics-key-here

# ── ENVIRONMENT-SPECIFIC (one per env) ──────────────────────
BACKEND_TOKEN_QA=your-qa-backend-token
BACKEND_TOKEN_STAGING=your-staging-backend-token
BACKEND_TOKEN_PROD=your-prod-backend-token

# ── TIER-SPECIFIC (one per tier) ────────────────────────────
AD_SDK_KEY_FREE=your-free-ad-sdk-key
AD_SDK_KEY_PAID=your-paid-ad-sdk-key

# ── RELEASE-ONLY (signing credentials) ─────────────────────
RELEASE_SIGNING_STORE_FILE=demo-release.jks
RELEASE_SIGNING_STORE_PASSWORD=your-store-password
RELEASE_SIGNING_KEY_ALIAS=your-key-alias
RELEASE_SIGNING_KEY_PASSWORD=your-key-password

